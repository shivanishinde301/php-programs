<?php
// --- PHP SCRIPT STARTS HERE ---
// 1. Configuration: Set Timezone to India
date_default_timezone_set('Asia/Kolkata');
// 2. Variable Declaration
$greeting = "Welcome to Web Development Lab";
$student_role = "Second Year Engineering Student";
// 3. String Output using Echo
// Note: We can embed HTML tags inside the PHP string
echo "<h2>$greeting</h2>";
echo "<p>You are logged in as: <b>$student_role</b></p>";
// 4. Date Logic
$current_date = date("l, d F Y"); // e.g., Monday, 02 December 2024
$current_time = date("h:i:s A"); // e.g., 03:30:45 PM
echo "<div class='time-box'>";
echo "Server Date: " . $current_date . "<br>";
echo "Server Time: " . $current_time;
echo "</div>";
